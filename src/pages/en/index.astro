---
import PageLayout from '@/layouts/PageLayout.astro';
import Hero from '@/components/blog/Hero.astro';
import FeaturedPost from '@/components/blog/FeaturedPost.astro';
import DiwanList from '@/components/blog/DiwanList.astro';
import SearchDialog from '@/components/global/SearchDialog.astro';
import { getFeaturedPost, getRecentPosts } from '@/utils/content';

const locale = 'en';
const featured = await getFeaturedPost(locale);
const recent = await getRecentPosts(locale, featured?.id, 5);
const allCount = (await getRecentPosts(locale, undefined, 999)).length;
---

<PageLayout
  title="raddah.net — Raddah's Diwan"
  description="A personal blog on technology, open-source software, and reflection."
  locale={locale}
>
  <SearchDialog locale={locale} />
  <Hero locale={locale} postCount={allCount} />
  {featured && <FeaturedPost post={featured} locale={locale} />}
  {recent.length > 0 && <DiwanList posts={recent} locale={locale} />}
</PageLayout>
