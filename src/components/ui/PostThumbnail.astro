---
import type { Locale } from '@/i18n';
import { formatNumber } from '@/utils/date';

interface Props {
  src?: string;
  alt?: string;
  locale: Locale;
  index?: number;
  ratio?: '16/9' | '3/2' | '2/1';
  class?: string;
}

const { src, alt, locale, index = 0, ratio = '3/2', class: className } = Astro.props;

const num = formatNumber(index + 1, locale).padStart(2, '0');
---

<div class={`thumb thumb--${ratio} ${className || ''}`}>
  {src ? (
    <img src={src} alt={alt || ''} class="thumb__img" loading="lazy" />
  ) : (
    <div class="thumb__placeholder">
      <span class="thumb__num">{num}</span>
    </div>
  )}
</div>

<style>
  .thumb {
    overflow: hidden;
    border-radius: var(--r-sm);
    background: var(--paper-deep);
    flex-shrink: 0;
  }
  .thumb--16\/9 { aspect-ratio: 16/9; }
  .thumb--3\/2  { aspect-ratio: 3/2; }
  .thumb--2\/1  { aspect-ratio: 2/1; }

  .thumb__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform var(--t-slow) var(--ease);
  }
  .thumb:hover .thumb__img { transform: scale(1.03); }

  .thumb__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #2a1f15 0%, #4a3525 50%, #6b4a30 100%);
    position: relative;
    display: grid;
    place-items: center;
  }
  .thumb__placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 40%, rgba(178, 58, 36, 0.4) 0%, transparent 50%),
      radial-gradient(circle at 70% 70%, rgba(244, 237, 224, 0.15) 0%, transparent 60%);
  }
  .thumb__num {
    font-family: var(--font-ar-display);
    font-size: clamp(2rem, 5vw, 4rem);
    color: rgba(244, 237, 224, 0.3);
    font-weight: 300;
    line-height: 1;
    z-index: 1;
  }
  :global([lang="en"]) .thumb__num,
  :global([lang="zh"]) .thumb__num {
    font-family: var(--font-mono);
  }
</style>
