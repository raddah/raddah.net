---
import type { Locale } from '@/i18n';
import { useTranslations } from '@/i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<dialog class="search-dialog" id="search-dialog" aria-label={t('nav.search')}>
  <div class="search-dialog__inner">
    <div class="search-dialog__head">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      <span class="search-dialog__label">{t('search.placeholder')}</span>
      <button class="search-dialog__close" id="search-close" aria-label={t('search.close')} type="button">
        <span class="kbd">ESC</span>
      </button>
    </div>
    <div id="pagefind-mount">
      <div class="search-dialog__loading">
        <div class="search-dialog__spinner"></div>
        <span>{t('search.loading')}</span>
      </div>
    </div>
    <div class="search-dialog__foot">
      <span><kbd>↑↓</kbd> {t('search.navigate')}</span>
      <span><kbd>↵</kbd> {t('search.open')}</span>
      <span class="search-dialog__brand">PAGEFIND</span>
    </div>
  </div>
</dialog>

<style>
  .search-dialog {
    border: 1px solid var(--ink);
    background: var(--paper);
    box-shadow: var(--shadow-lg);
    width: min(640px, calc(100vw - 2rem));
    padding: 0;
    color: var(--ink);
    border-radius: var(--r-sm);
    max-height: 80vh;
  }
  .search-dialog::backdrop {
    background: rgba(28, 20, 16, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .search-dialog__inner { 
    display: flex; 
    flex-direction: column; 
    max-height: 80vh;
  }
  .search-dialog__head {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    padding: var(--s-4) var(--s-5);
    border-block-end: 1px solid var(--rule);
    color: var(--ink-mute);
    flex-shrink: 0;
  }
  .search-dialog__label {
    flex: 1;
    font-family: var(--font-ar-body);
    font-size: var(--t-base);
    color: var(--ink-faint);
    font-style: italic;
  }
  .search-dialog__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .kbd {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    border: 1px solid var(--rule);
    padding: 2px var(--s-2);
    border-radius: var(--r-sm);
    color: var(--ink-mute);
  }
  .search-dialog__foot {
    display: flex;
    justify-content: space-between;
    padding: var(--s-3) var(--s-5);
    border-block-start: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-mute);
    flex-wrap: wrap;
    gap: var(--s-3);
    flex-shrink: 0;
  }
  .search-dialog__foot kbd {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    border: 1px solid var(--rule);
    padding: 1px var(--s-2);
    border-radius: var(--r-sm);
  }
  .search-dialog__brand {
    opacity: 0.5;
    letter-spacing: 0.1em;
  }
  .search-dialog__loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-3);
    padding: var(--s-7);
    color: var(--ink-mute);
    font-family: var(--font-ar-body);
    font-style: italic;
  }
  .search-dialog__spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--rule);
    border-top-color: var(--vermillion);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Pagefind UI overrides */
  :global(#pagefind-mount) {
    --pagefind-ui-primary: var(--vermillion);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--paper);
    --pagefind-ui-border: var(--rule);
    --pagefind-ui-tag: var(--paper-deep);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 2px;
    --pagefind-ui-image-border-radius: 2px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-ar-body);
  }
  :global(#pagefind-mount .pagefind-ui__search-input) {
    font-family: inherit;
    font-size: var(--t-lg);
    padding: var(--s-3) var(--s-4);
    border: 1px solid var(--rule);
    border-radius: var(--r-sm);
    background: var(--paper);
    color: var(--ink);
  }
  :global(#pagefind-mount .pagefind-ui__search-input:focus) {
    outline: 2px solid var(--vermillion);
    outline-offset: 2px;
    border-color: var(--vermillion);
  }
</style>

<script>
  (function() {
    const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('search-close');
    const mount = document.getElementById('pagefind-mount');
    let initialized = false;
    let pagefindUI: any = null;

    async function initPagefind() {
      if (initialized || !mount) return;
      initialized = true;
      
      try {
        // Preload the CSS
        const cssLink = document.createElement('link');
        cssLink.rel = 'stylesheet';
        cssLink.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(cssLink);

        // Dynamically import Pagefind UI
        const module = await import(/* @vite-ignore */ '/pagefind/pagefind-ui.js');
        const PagefindUI = module.default;
        
        // Clear loading state
        mount.innerHTML = '';
        
        pagefindUI = new PagefindUI({
          element: '#pagefind-mount',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          debounceTimeoutMs: 150,
          translations: {
            placeholder: '',
            clear_search: 'Clear',
            load_more: 'Load more results',
            search_label: 'Search',
            filters_label: 'Filters',
            zero_results: 'No results found',
            many_results: 'results found',
            one_result: 'result found',
            alt_search: 'No results for [SEARCH_TERM]. Showing results for [DIFFERENT_TERM] instead.',
            search_suggestion: 'No results for [SEARCH_TERM]. Try one of the following searches:',
            searching: 'Searching...',
          }
        });

        return true;
      } catch (err) {
        console.error('[Search] Failed to initialize:', err);
        if (mount) {
          mount.innerHTML = `
            <div style="padding: 2rem; text-align: center; color: var(--ink-mute);">
              <p style="margin-bottom: 1rem; font-style: italic;">Search index not available.</p>
              <p style="font-size: var(--t-xs); font-family: var(--font-mono);">Run <code style="background: var(--paper-deep); padding: 0.2rem 0.4rem; border-radius: var(--r-sm);">npm run build</code> to generate the search index.</p>
            </div>
          `;
        }
        return false;
      }
    }

    // Open search dialog
    async function openSearch() {
      if (!dialog) return;
      dialog.showModal();
      document.body.style.overflow = 'hidden';
      
      const success = await initPagefind();
      
      if (success) {
        // Focus the input after a short delay to ensure rendering
        requestAnimationFrame(() => {
          setTimeout(() => {
            const input = mount?.querySelector('.pagefind-ui__search-input') as HTMLInputElement | null;
            input?.focus();
          }, 100);
        });
      }
    }

    // Close search dialog
    function closeSearch() {
      if (!dialog) return;
      dialog.close();
      document.body.style.overflow = '';
    }

    // Event listeners
    document.addEventListener('open-search', openSearch);
    closeBtn?.addEventListener('click', closeSearch);
    
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) closeSearch();
    });

    dialog?.addEventListener('close', () => {
      document.body.style.overflow = '';
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      // Cmd/Ctrl + K to open
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
      // Escape to close
      if (e.key === 'Escape' && dialog?.open) {
        closeSearch();
      }
    });
  })();
</script>
