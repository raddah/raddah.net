{
  "name": "raddah-net",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "raddah.net — Trilingual personal blog (ar/en/zh) built with Astro on Cloudflare",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint . --ext .ts,.astro",
    "format": "prettier --write .",
    "postbuild": "pagefind --site dist",
    "new:post": "tsx scripts/new-post.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "astro": "^5.0.0",
    "pagefind": "^1.1.0",
    "rehype-pretty-code": "^0.14.0",
    "shiki": "^1.22.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
